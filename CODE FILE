# 4️⃣ TUMOUR GROWTH (2D)
# -----------------------------
plt.figure()
plt.plot(tumour_size)
plt.title("Tumour Growth Curve")
plt.xlabel("Time")
plt.ylabel("Cancer Cells")
plt.show()
